page{background:#f6f7f9}
.container{padding:30rpx}
.title{font-size:40rpx;font-weight:bold;text-align:center;margin:20rpx 0 40rpx}
.item{background:#fff;border-radius:16rpx;padding:24rpx;margin-bottom:16rpx}
.picker-box{background:#f5f5f5;padding:16rpx;border-radius:10rpx}
.blue-bg{background:#eef7ff}
.tip-box{background:#fff1f0}
.tip-text{color:#f56c6c}
.result{background:#fff;border-radius:16rpx;padding:30rpx;text-align:center;margin:20rpx 0}
.total-price{font-size:36rpx;color:#ff2d4b;font-weight:bold}
.btn-wrap{display:flex;gap:16rpx;margin:20rpx 0}
.btn{flex:1;padding:20rpx;border-radius:12rpx;text-align:center}
.reset-btn{background:#eee}
.copy-btn{background:#007AFF;color:#fff}
.save-btn{background:#10b981;color:#fff;padding:20rpx;border-radius:12rpx;text-align:center;margin-bottom:20rpx}
.sub-title{font-size:30rpx;margin:30rpx 0 10rpx}
.holiday-card{background:#fff;border-radius:16rpx;padding:20rpx}
.add-holiday-btn{background:#edf7ff;color:#007AFF;padding:16rpx;border-radius:10rpx;text-align:center}
.holiday-list{margin-top:16rpx}
.hi{display:flex;justify-content:space-between;padding:10rpx 0;border-bottom:1rpx solid #eee}
.del{color:red;font-size:24rpx}
.empty{color:#999;text-align:center;display:block;padding:20rpx}
.history-item{background:#fff;border-radius:16rpx;padding:20rpx;margin-bottom:12rpx}
.h-top{display:flex;justify-content:space-between;margin-bottom:10rpx}
.h-op{display:flex;gap:10rpx;justify-content:flex-end;margin-top:10rpx}
.op{padding:6rpx 12rpx;background:#f5f5f5;border-radius:6rpx;font-size:24rpx}
.del{background:#ffeaea;color:red}
.clear-all{text-align:center;color:red;margin:30rpx 0}
