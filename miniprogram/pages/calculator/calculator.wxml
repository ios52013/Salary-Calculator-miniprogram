<scroll-view scroll-y class="page-scroll">
  <view class="container">
    <view class="title">阿姨工资精准核算</view>
    <view class="item">
      <text>阿姨姓名备注</text>
      <input placeholder="输入阿姨姓名/备注" bindinput="inputName" value="{{name}}" />
    </view>
    <view class="item start-item" style="background:{{startBgColor}}">
      <text>上户日期</text>
      <picker mode="date" end="{{todayDate}}" value="{{startDate}}" bindchange="bindStartDate">
        <view class="picker-box">{{startDate || '请选择上户日期'}}</view>
      </picker>
    </view>
    <view class="item start-item" style="background:{{startBgColor}}">
      <text>上户具体时间</text>
      <picker mode="time" value="{{startTime}}" bindchange="bindStartTime">
        <view class="picker-box">{{startTime || '请选择上户时间'}}</view>
      </picker>
    </view>
    <view class="item end-item" style="background:{{endBgColor}}">
      <text>下户日期</text>
      <picker mode="date" end="{{todayDate}}" value="{{endDate}}" bindchange="bindEndDate">
        <view class="picker-box">{{endDate || '请选择下户日期'}}</view>
      </picker>
    </view>
    <view class="item end-item" style="background:{{endBgColor}}">
      <text>下户具体时间</text>
      <picker mode="time" value="{{endTime}}" bindchange="bindEndTime">
        <view class="picker-box">{{endTime || '请选择下户时间'}}</view>
      </picker>
    </view>

    <!-- 休息日：日历多选（新增，不改动原有布局） -->
    <view class="sub-title">休息日（可多选）</view>
    <view class="holiday-card">
      <picker mode="date" bindchange="pickAddRestDay">
        <view class="add-holiday-btn">➕ 选择日期添加休息日</view>
      </picker>
      <view class="holiday-list">
        <view class="hi" wx:for="{{restDayList}}" wx:key="*this">
          <text>{{item}}</text>
          <view class="del" bindtap="delRestDay" data-date="{{item}}">删除</view>
        </view>
        <text wx:if="{{restDayList.length===0}}" class="empty">暂无休息</text>
      </view>
    </view>

    <view class="item blue-bg">
      <text>总服务时长：{{showDayHour}}</text>
    </view>
    <view class="item blue-bg" wx:if="{{restDayList.length > 0}}">
      <text>休息：{{restDayList.length}}天 → 实际服务：{{realShowDayHour}}</text>
    </view>
    <view class="item">
      <text>每月约定总薪资（元）</text>
      <input 
        type="digit" 
        placeholder="请输入月薪" 
        bindinput="inputTotalSalary" 
        value="{{totalSalary}}" 
      />
    </view>
    <view class="item">
      <text>每月按多少天结算</text>
      <input type="digit" placeholder="例如：26/29/30" 
             value="{{monthDaysInput}}" 
             bindinput="inputMonthDays"
             bindblur="blurMonthDays" />
    </view>
    <view class="item blue-bg">
      <text>日薪：{{daySalary}} 元</text>
      <text>时薪：{{hourSalary}} 元</text>
    </view>
    <view class="item tip-box" wx:if="{{holidayTip}}">
      <text class="tip-text">{{holidayTip}}</text>
    </view>
    <view class="result">
      <view>普通工资：{{normalWage}} 元</view>
      <view>节假日双倍：{{holidayWage}} 元</view>
      <view class="total-price">合计：{{finalSalary}} 元</view>
    </view>
    <view class="btn-wrap">
      <view class="btn reset-btn" bindtap="resetAll">一键清空</view>
      <view class="btn copy-btn" bindtap="copyWageInfo">一键复制</view>
    </view>
    <view class="save-btn" bindtap="saveRecord" wx:if="{{finalSalary != '0.00'}}">💾 保存本次记录</view>
    <view class="sub-title">自定义节假日</view>
    <view class="holiday-card">
      <picker mode="date" bindchange="pickAddHoliday">
        <view class="add-holiday-btn">➕ 选择日期添加</view>
      </picker>
      <view class="holiday-list">
        <view class="hi" wx:for="{{userHolidayList}}" wx:key="*this">
          <text>{{item}}</text>
          <view class="del" bindtap="delHoliday" data-date="{{item}}">删除</view>
        </view>
        <text wx:if="{{userHolidayList.length===0}}" class="empty">暂无</text>
      </view>
    </view>
    <view class="sub-title">历史记录</view>
    <view class="history-item" wx:for="{{historyList}}" wx:key="index">
      <view class="h-top">
        <text>{{item.name || '未备注'}}</text>
        <text style="font-size:24rpx;color:#999">{{item.createTime}}</text>
      </view>
      <view>时长：{{item.showDayHour}}</view>
      <view>合计：{{item.finalSalary}} 元</view>
      <view class="h-op">
        <view class="op" bindtap="copyHistory" data-idx="{{index}}">复制</view>
        <view class="op del" bindtap="delOneHistory" data-idx="{{index}}">删除</view>
      </view>
    </view>
    <view class="clear-all" bindtap="clearAllHistory" wx:if="{{historyList.length>0}}">清空所有历史</view>
  </view>
</scroll-view>