page {
  background: #f6f7f9;
  padding: 30rpx;
  margin: 0;
}
.container {
  width: 100%;
}
.page-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
  color: #111;
}
.tool-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.tool-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.tool-icon {
  font-size: 60rpx;
  width: 80rpx;
  text-align: center;
}
.tool-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.tool-name {
  font-size: 32rpx;
  color: #111;
  font-weight: 500;
}
.tool-desc {
  font-size: 26rpx;
  color: #888;
}
.tool-arrow {
  font-size: 36rpx;
  color: #ccc;
}