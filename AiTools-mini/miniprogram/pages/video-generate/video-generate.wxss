page {
  background-color: #f6f7f9;
  padding: 30rpx;
  margin: 0;
}
.page-wrap {
  width: 100%;
  box-sizing: border-box;
}
.form-item {
  margin-bottom: 40rpx;
}
.form-label {
  display: block;
  font-size: 32rpx;
  color: #111;
  margin-bottom: 20rpx;
  font-weight: 500;
}

/* 图片上传网格 */
.img-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.img-card {
  width: 160rpx;
  height: 160rpx;
  position: relative;
}
.img-card image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  background: #eee;
}
.del-icon {
  width: 44rpx;
  height: 44rpx;
  background: #f53f3f;
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 44rpx;
  font-size: 30rpx;
  position: absolute;
  top: -12rpx;
  right: -12rpx;
}
.add-img-btn {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.plus {
  font-size: 60rpx;
  color: #999;
}

/* 文案输入框 */
.text-input {
  width: 100%;
  height: 220rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.word-num {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 下拉选择框通用 */
.picker-box {
  background: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

/* 生成按钮 */
.generate-btn {
  background: #07c160;
  color: #fff;
  border: none;
  border-radius: 999rpx;
  height: 90rpx;
  font-size: 32rpx;
  margin-bottom: 40rpx;
}
.generate-btn[disabled] {
  background: #cccccc !important;
}

/* 视频结果区 */
.result-title {
  font-size: 34rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}
.video-player {
  width: 100%;
  border-radius: 12rpx;
  background: #000;
}
.save-btn {
  margin-top: 24rpx;
  background: #007aff;
  color: #fff;
  border-radius: 999rpx;
}