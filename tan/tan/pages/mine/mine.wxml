<!-- 用户信息区域 -->
<view class="userCard">
  <image src="{{userInfo.avatarUrl}}" mode="widthFix"></image>
  <text class="nick">{{userInfo.nickName}}</text>
</view>

<!-- 功能菜单 -->
<view class="menuList">
  <view class="menuItem" bindtap="goSeller">
    <text>摊主中心 / 我要出摊</text>
    <text>></text>
  </view>

  <view class="menuItem" bindtap="goOrder">
    <text>我的订单</text>
    <text>></text>
  </view>

  <view class="menuItem">
    <text>我的收藏</text>
    <text>></text>
  </view>

  <view class="menuItem">
    <text>帮助与反馈</text>
    <text>></text>
  </view>
</view>