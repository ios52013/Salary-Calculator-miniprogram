page{
  background: #f5f7fa;
}
.detail-box{
  padding-bottom: 40rpx;
}
.top-banner{
  width: 100%;
}
.banner-img{
  width: 100%;
  height: 360rpx;
}
.info-card{
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 25rpx;
}
.name{
  font-size: 34rpx;
  font-weight: bold;
  color: #222;
}
.tag{
  font-size: 26rpx;
  color: #0F3460;
  margin: 12rpx 0;
}
.addr,.time{
  font-size: 25rpx;
  color: #555;
  margin-top: 10rpx;
}
.intro-card{
  background: #fff;
  margin: 0 20rpx;
  border-radius: 16rpx;
  padding: 25rpx;
}
.intro-title{
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 15rpx;
}
.intro-text{
  font-size: 25rpx;
  color: #666;
  line-height: 1.6;
}
.btn-wrap{
  margin: 40rpx 20rpx 0;
}
.call-btn{
  background: #0F3460;
  color: #fff;
  border-radius: 12rpx;
}

.msg-btn{
  margin-top:20rpx;
  background:#fff;
  color:#0F3460;
  border:1rpx solid #0F3460;
}

.look-goods{
  margin: 20rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #0F3460;
  text-align: center;
}