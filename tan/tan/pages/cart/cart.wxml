<view class="cart-container">
  <view class="cart-list" wx:if="{{cartList.length > 0}}">
    <view class="cart-item" wx:for="{{cartList}}" wx:key="goodsId">
      <checkbox class="check-box" checked="{{item.isCheck}}" bindchange="toggleCheck" data-index="{{index}}"></checkbox>
      <image class="cart-img" src="{{item.goodsImg}}" mode="aspectFill"></image>
      <view class="cart-right">
        <view class="goods-name">{{item.goodsName}}</view>
        <view class="goods-price">¥{{item.price}}</view>
        <view class="num-control">
          <text class="num-minus" bindtap="reduceNum" data-index="{{index}}">-</text>
          <text class="num-text">{{item.count}}</text>
          <text class="num-add" bindtap="addNum" data-index="{{index}}">+</text>
          <text class="del-text" bindtap="delGoods" data-index="{{index}}">删除</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-cart" wx:else>
    购物车空空如也，快去挑选商品吧~
  </view>

  <!-- 底部结算栏 -->
  <view class="cart-footer" wx:if="{{cartList.length > 0}}">
    <checkbox checked="{{isAllCheck}}" bindchange="toggleAllCheck"></checkbox>
    <text class="all-txt">全选</text>
    <view class="total-box">
      <text>合计：<text class="total-price">¥{{totalPrice}}</text></text>
      <button class="settle-btn" bindtap="goSettle">去结算</button>
    </view>
  </view>
</view>