page{
  background: #f5f5f5;
}
.cart-container{
  padding: 20rpx;
}
.cart-item{
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
}
.check-box{
  margin-right: 15rpx;
}
.cart-img{
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
}
.cart-right{
  flex: 1;
  margin-left: 15rpx;
}
.goods-name{
  font-size: 28rpx;
  color: #333;
}
.goods-price{
  font-size: 30rpx;
  color: #f53f3f;
  margin: 10rpx 0;
}
.num-control{
  display: flex;
  align-items: center;
}
.num-minus,.num-add{
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  border: 1rpx solid #eee;
  font-size: 28rpx;
}
.num-text{
  width: 70rpx;
  text-align: center;
  font-size: 28rpx;
}
.del-text{
  color: #999;
  font-size: 26rpx;
  margin-left: 30rpx;
}
.empty-cart{
  text-align: center;
  margin-top: 200rpx;
  font-size: 28rpx;
  color: #999;
}
.cart-footer{
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-sizing: border-box;
}
.all-txt{
  font-size: 28rpx;
  margin-left: 10rpx;
}
.total-box{
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}
.total-price{
  color: #f53f3f;
  font-size: 32rpx;
  font-weight: bold;
  margin: 0 20rpx;
}
.settle-btn{
  width: 160rpx;
  height: 70rpx;
  line-height: 70rpx;
  background: #ff6727;
  color: #fff;
  font-size: 26rpx;
}