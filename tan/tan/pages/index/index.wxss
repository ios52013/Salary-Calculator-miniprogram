page{
  background: #f5f7fa;
}
.home-page{
  padding-bottom: 30rpx;
}
/* 搜索栏 */
.search-bar{
  display: flex;
  align-items: center;
  background: #fff;
  margin: 20rpx;
  border-radius: 50rpx;
  padding: 0 25rpx;
  height: 70rpx;
}
.search-input{
  flex: 1;
  font-size: 26rpx;
}
.search-icon{
  font-size: 28rpx;
  color: #999;
}

/* 轮播 */
.home-swiper{
  margin: 0 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.swiper-img{
  width: 100%;
  height: 320rpx;
}

/* 分类导航 */
.cate-wrap{
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx 10rpx;
}
.cate-item{
  width: 25%;
  text-align: center;
  margin-bottom: 20rpx;
}
.cate-icon{
  font-size: 44rpx;
  margin-bottom: 10rpx;
}
.cate-name{
  font-size: 26rpx;
  color: #333;
}

/* 公告 */
.notice-box{
  display: flex;
  align-items: center;
  background: #fff;
  margin: 0 20rpx;
  padding: 20rpx;
  border-radius: 12rpx;
}
.notice-left{
  font-size: 26rpx;
  color: #f53f3f;
  margin-right: 20rpx;
}
.notice-text{
  flex: 1;
  font-size: 24rpx;
  color: #666;
}

/* 热门摊位标题 */
.hot-title{
  display: flex;
  justify-content: space-between;
  padding: 30rpx 20rpx 10rpx;
  font-size: 30rpx;
  font-weight: bold;
}
.more-text{
  font-size: 26rpx;
  color: #0F3460;
  font-weight: normal;
}

/* 摊位列表 */
.hot-stall-list{
  padding: 0 20rpx;
}
.stall-item{
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 15rpx;
}
.stall-img{
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
}
.stall-info{
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.stall-name{
  font-size: 28rpx;
  font-weight: 500;
}
.stall-type{
  font-size: 24rpx;
  color: #999;
  margin: 8rpx 0;
}
.stall-distance{
  font-size: 24rpx;
  color: #07c160;
}