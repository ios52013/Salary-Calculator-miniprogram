page{
  background: #f5f7fa;
  padding: 20rpx;
}
.join-box{
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}
.title{
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
  color: #0F3460;
}
.form-item{
  margin-bottom: 30rpx;
}
.label{
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}
.input{
  width: 100%;
  height: 70rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  padding: 0 15rpx;
  font-size: 26rpx;
}
.picker{
  width: 100%;
  height: 70rpx;
  line-height: 70rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  padding: 0 15rpx;
  font-size: 26rpx;
  color: #666;
}
.textarea{
  width: 100%;
  height: 120rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  padding: 15rpx;
  font-size: 26rpx;
}
.submit-btn{
  background: #0F3460;
  color: #fff;
  margin-top: 20rpx;
  border-radius: 10rpx;
}