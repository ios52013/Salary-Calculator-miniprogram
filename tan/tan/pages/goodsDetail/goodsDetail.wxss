page{
  background:#f5f5f5;
}
.detail-img{
  width:100%;
  height:600rpx;
}
.info-box{
  background:#fff;
  padding:20rpx;
  margin-top:15rpx;
}
.goods-name{
  font-size:32rpx;
  font-weight:bold;
}
.goods-price{
  font-size:36rpx;
  color:#f53f3f;
  margin:15rpx 0;
}
.stock-txt{
  font-size:26rpx;
  color:#999;
}
.num-box{
  background:#fff;
  padding:25rpx 20rpx;
  margin-top:15rpx;
  display:flex;
  align-items:center;
  justify-content:space-between;
}
.num-wrap{
  display:flex;
  align-items:center;
}
.minus,.add{
  width:60rpx;
  height:60rpx;
  line-height:60rpx;
  text-align:center;
  border:1rpx solid #eee;
  font-size:30rpx;
}
.num-input{
  width:80rpx;
  text-align:center;
  font-size:28rpx;
}

/* --------------------------
✅ 顶部购物车图标 + 数量角标
-------------------------- */
.top-cart-icon{
  position: fixed;
  top: 30rpx;
  right: 30rpx;
  z-index: 999;
  width: 70rpx;
  height: 70rpx;
}
.cart-img{
  width: 100%;
  height: 100%;
}
.cart-num{
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #ff3a3a;
  color: #fff;
  font-size: 22rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  line-height: 36rpx;
  text-align: center;
}

/* --------------------------
✅ 底部按钮：并排双按钮（产品级优化）
-------------------------- */
.bottom-btn{
  position:fixed;
  bottom:0;
  left:0;
  width:100%;
  padding:20rpx;
  box-sizing:border-box;
  background:#fff;
  display: flex;
}

/* 去购物车 → 浅色次要按钮 */
.btn-cart {
  width: 30%;
  background: #fff;
  color: #333;
  border: 1rpx solid #ddd;
  margin: 0;
}

/* 加入购物车 → 橙色主按钮 */
.btn-add {
  width: 68%;
  background: #ff6727;
  color: #fff;
  margin-left: 2%;
}