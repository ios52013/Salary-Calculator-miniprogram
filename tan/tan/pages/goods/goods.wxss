.addBox {
  background: #0F3460;
  color: #fff;
  text-align: center;
  padding: 25rpx;
  margin: 20rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.list {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.item {
  display: flex;
  align-items: center;
  padding: 30rpx 25rpx;
  border-bottom: 1rpx solid #f2f2f2;
}

.item:last-child {
  border-bottom: none;
}

.name {
  flex: 1;
  font-size: 30rpx;
}

.price {
  margin-right: 20rpx;
  font-size: 30rpx;
  color: #f30;
}

.del {
  color: #fff;
  background: #f56c6c;
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
}