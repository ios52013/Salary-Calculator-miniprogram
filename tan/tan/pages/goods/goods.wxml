<!-- 新增商品按钮 -->
<view class="addBox" bindtap="addGoods">
  + 新增商品
</view>

<!-- 商品列表 -->
<view class="list">
  <view class="item" wx:for="{{goodsList}}" wx:key="index">
    <view class="name">{{item.name}}</view>
    <view class="price">￥{{item.price}}</view>
    <view class="del" bindtap="delGoods" data-index="{{index}}">删除</view>
  </view>
</view>