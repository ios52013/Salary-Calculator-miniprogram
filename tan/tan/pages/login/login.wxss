page {
  background-color: #F5F5F5;
}
.container {
  padding-top: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.logoText {
  font-size: 72rpx;
  font-weight: bold;
  color: #0F3460;
}
.subTitle {
  font-size: 28rpx;
  color: #666;
  margin: 20rpx 0 100rpx;
}
.loginBtn {
  width: 520rpx;
  background-color: #0F3460;
  color: #fff;
  border-radius: 50rpx;
}
.userBox {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}
.userBox image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}
.nick {
  font-size: 32rpx;
  color: #333;
  margin-top: 20rpx;
}
.enterBtn {
  background: #194578;
}