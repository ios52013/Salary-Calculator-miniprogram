<view class="container">
  <view class="order-list">
    <view class="order-item" wx:for="{{orderList}}" wx:key="orderId">
      <view class="order-header">
        <text>订单号：{{item.orderId}}</text>
        <text style="color:#0F3460; font-weight:bold; margin-left:20rpx;">
          <text wx:if="{{!item.status || item.status == 'paid'}}">待接单</text>
          <text wx:if="{{item.status == 'received'}}">已接单</text>
          <text wx:if="{{item.status == 'meal'}}">已出餐</text>
          <text wx:if="{{item.status == 'finished'}}">已完成</text>
          <text wx:if="{{item.status == 'canceled'}}">已取消</text>
        </text>
      </view>


      <!-- 正确：循环goods数组 -->
      <view class="goods-list">
        <view class="goods-item" wx:for="{{item.goods}}" wx:key="name">
          <text>{{item.goodsName}}</text>
          <text>x{{item.count}}</text>
        </view>
      </view>

      <view class="order-footer">
        <text>{{item.createTime}}</text>
        <text>金额：¥{{item.totalPrice}}</text>
      </view>

      <view style="margin-top:20rpx; text-align:right;" wx:if="{{!item.status || item.status == 'paid'}}">
        <button size="mini" type="primary" bindtap="receiveOrder" data-index="{{index}}">确认接单</button>
      </view>

      <view style="margin-top:20rpx; text-align:right;" wx:if="{{item.status == 'received'}}">
        <button size="mini" type="primary" bindtap="mealOrder" data-index="{{index}}">出餐</button>
      </view>
    </view>

    <view class="empty" wx:if="{{orderList.length === 0}}">
      暂无订单
    </view>
  </view>
</view>