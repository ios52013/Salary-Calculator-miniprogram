page{
  background-color: #f5f7fa;
}
.container{
  padding: 20rpx;
}

/* 头部摊位信息 */
.sellerHeader{
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
}
.shopInfo{
  flex: 1;
}
.shopName{
  font-size: 32rpx;
  font-weight: bold;
  color: #222;
}
.shopDesc{
  font-size: 26rpx;
  color: #666;
  margin: 6rpx 0;
}
.shopTime{
  font-size: 24rpx;
  color: #888;
}
.shopInp{
  font-size: 26rpx;
  padding: 6rpx 0;
  border-bottom: 1rpx solid #eee;
  margin: 4rpx 0;
}
.editBtn{
  font-size: 26rpx;
  color: #0F3460;
  border: 1rpx solid #0F3460;
  padding: 8rpx 14rpx;
  border-radius: 6rpx;
}

/* 营业状态 */
.statusBox{
  background: #fff;
  padding: 20rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.statusText{
  font-size: 28rpx;
  margin-right: 15rpx;
}
.openText{
  color: #16a34a;
  font-size: 28rpx;
  margin-left: 10rpx;
}
.closeText{
  color: #ef4444;
  font-size: 28rpx;
  margin-left: 10rpx;
}

/* 商品标题 */
.goodsTit{
  font-size: 32rpx;
  font-weight: 500;
  margin: 30rpx 0 15rpx;
  color: #333;
  text-align: center;
}

/* 表头和商品行的核心对齐规则 */
.goodsHead,
.goodsItem {
  display: flex;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
}

.goodsHead {
  padding: 0 10rpx 10rpx;
  font-size: 26rpx;
  color: #666;
  white-space: nowrap; /* 强制表头文字不换行 */
}

.goodsItem {
  background: #fff;
  border-radius: 10rpx;
  padding: 20rpx 15rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

/* 每一列宽度强制固定，保证表头和内容1:1对齐 */
.col1 { width: 12%; text-align: center; }
.col2 { width: 38%; padding: 0 10rpx; }
.col3 { width: 15%; text-align: center; }
.col4 { width: 15%; text-align: center; }
.col5 { width: 20%; text-align: center; }

/* 输入框样式 */
.col2, .col3, .col4 {
  font-size: 28rpx;
  padding: 8rpx;
  background: #f7f8fa;
  border-radius: 6rpx;
  border: none;
}

/* 序号样式 */
.col1 {
  font-size: 28rpx;
  user-select: none;
}

/* 删除按钮 */
.delBtn {
  color: #e53e3e;
  font-size: 26rpx;
  padding: 6rpx 10rpx;
  border: 1rpx solid #e53e3e;
  border-radius: 6rpx;
}

/* 添加商品 */
.addGoods{
  text-align: center;
  margin: 30rpx auto;
  width: 90%;
  line-height: 80rpx;
  background: #f0f4f9;
  color: #0F3460;
  border: 1rpx dashed #0F3460;
  border-radius: 10rpx;
  font-size: 30rpx;
}

/* 保存按钮 */
.saveBtn{
  background: #079452;
  color: #fff;
  margin: 10rpx 20rpx;
  border-radius: 10rpx;
}
.tools button{
  background: #0F3460;
  color: #fff;
  margin: 15rpx 20rpx;
  border-radius: 10rpx;
}
/* 摊主页面追加美化 */
.sellerHeader{
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.goodsItem{
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.saveBtn{
  border-radius: 12rpx !important;
}
.tools button{
  border-radius: 12rpx !important;
}
.addGoods{
  border-radius: 12rpx;
}
.goods-img{
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-right: 10rpx;
}
.col2{
  flex:1;
}

/* 商品列表图片样式 */
.goods-img {
  width: 70rpx;
  height: 70rpx;
  border-radius: 8rpx;
  margin-right: 10rpx;
}

/* 未入驻提示样式 */
.no-stall-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
}
.no-tip {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}
.go-join-btn {
  background: #1377ff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
  padding: 10rpx 30rpx;
}
